{
  "name": "jingpai",
  "version": "0.14.2",
  "private": true,
  "description": "净排 — 纯本地、不登录的公众号 Markdown 排版工具，隐私安全 + AI 自带 key",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "release": "npm run check && npm run build",
    "deploy:github": "gh-pages -d dist"
  },
  "dependencies": {
    "@milkdown/kit": "^7.17.0",
    "@milkdown/plugin-listener": "^7.17.0",
    "dompurify": "^3.1.5",
    "marked": "^18.0.5",
    "remark-directive": "^3.0.1",
    "turndown": "^7.2.4",
    "vue": "^3.4.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "vite": "^5.3.3",
    "vitest": "^2.0.0"
  }
}
